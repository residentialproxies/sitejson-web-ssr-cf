SITEJSON_API_BASE_URL=http://127.0.0.1:8787
SITEJSON_API_KEY=dev-api-key
SITEJSON_PROXY_TIMEOUT_MS=15000
PUBLIC_SITE_BASE_URL=https://sitejson.com

# GitHub OAuth
GITHUB_CLIENT_ID=replace_with_github_oauth_client_id
GITHUB_CLIENT_SECRET=replace_with_github_oauth_client_secret_or_pat

# Session signing secret (use a long random string in production)
AUTH_SESSION_SECRET=replace_with_long_random_secret
SITEJSON_STARTER_CREDITS_D1_BINDING=SITEJSON_CREDITS_DB

# Optional tier rate limits (req/min)
SITEJSON_RATE_LIMIT_ANONYMOUS_RPM=10
SITEJSON_RATE_LIMIT_FREE_RPM=10
SITEJSON_RATE_LIMIT_PRO_RPM=100
